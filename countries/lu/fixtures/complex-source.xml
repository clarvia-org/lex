      <chapter id="chapter_1" scl:hidden="false" scl:subject1="http://data.legilux.public.lu/resource/authority/legal-subject/2200" scl:subject1lbl="jouissance des droits civils">
						<num>Chapitre Ier.</num>
						<heading>De la jouissance des droits civils </heading>
						<article id="art_7" scl:uri="/eli/etat/leg/code/civil/art_7">
							<scl:JOLUXWork>
								<scl:JOLUXComplexWork>
									<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/code/civil/art_7</scl:jolux>
								</scl:JOLUXComplexWork>
								<scl:JOLUXLegalResource>
									<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/code/civil/art_7/20180401</scl:jolux>
									<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1804/03/21/n1</scl:jolux>
									<scl:jolux scl:lg="fra" scl:name="title">Art. 7.</scl:jolux>
									<scl:jolux scl:name="dateApplicability">2018-04-01</scl:jolux>
									<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
								</scl:JOLUXLegalResource>
							</scl:JOLUXWork>
							<scl:indexterms>
								<scl:indexterm>
									<scl:label>Droits civiques</scl:label>
								</scl:indexterm>
								<scl:indexterm>
									<scl:label>Droits civils</scl:label>
								</scl:indexterm>
								<scl:indexterm>
									<scl:label>Citoyen (qualité de)</scl:label>
								</scl:indexterm>
							</scl:indexterms>
							<num>Art. 7.</num>
							<alinea>
								<content>
									<p>L'exercice des droits civils est indépendant de la qualité de citoyen, laquelle ne s'acquiert et ne se conserve que conformément à la loi constitutionnelle.</p>
								</content>
							</alinea>
						</article>
						<article id="art_8" scl:uri="/eli/etat/leg/code/civil/art_8">
							<scl:JOLUXWork>
								<scl:JOLUXComplexWork>
									<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/code/civil/art_8</scl:jolux>
								</scl:JOLUXComplexWork>
								<scl:JOLUXLegalResource>
									<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/code/civil/art_8/20180401</scl:jolux>
									<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1804/03/21/n1</scl:jolux>
									<scl:jolux scl:lg="fra" scl:name="title">Art. 8.</scl:jolux>
									<scl:jolux scl:name="dateApplicability">2018-04-01</scl:jolux>
									<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
								</scl:JOLUXLegalResource>
							</scl:JOLUXWork>
							<scl:indexterms>
								<scl:indexterm>
									<scl:label>Citoyen (qualité de)</scl:label>
								</scl:indexterm>
							</scl:indexterms>
							<num>Art. 8.</num>
							<alinea>
								<content>
									<p>Tout Luxembourgeois jouira des droits civils.</p>
								</content>
							</alinea>
						</article>
