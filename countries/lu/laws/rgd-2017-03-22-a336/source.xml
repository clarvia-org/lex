cl:jolux scl:name="license">http://creativecommons.org/licenses/by/4.0/</scl:jolux><scl:jolux scl:name="userFormat">http://data.legilux.lu/resource/authority/user-format/pdf</scl:jolux><scl:jolux scl:name="format">http://publications.europa.eu/resource/authority/file-type/PDF</scl:jolux><scl:jolux scl:name="isExemplifiedBy">http://data.legilux.public.lu/file/eli-etat-leg-rgd-2017-03-22-a336-consolide-20171119-fr-pdf.pdf</scl:jolux></scl:JOLUXManifestation></identification><lifecycle source="#"><eventRef date="2017-03-22" id="e1" originatingExpression="true" source="#ro1" type="generation"/><eventRef date="2017-11-19" id="e2" originatingExpression="true" source="#rp2" type="amendment"/></lifecycle><analysis source="#"><passiveModifications><textualMod id="pm1" incomplete="false" type="replacement"><source href="/eli/etat/leg/rgd/2017/11/10/a976/jo"/><destination href="#art_1er"/></textualMod></passiveModifications></analysis><references source="#"><original href="/eli/etat/leg/rgd/2017/03/22/a336/jo" id="ro1" showAs="Original"/><passiveRef href="/eli/etat/leg/rgd/2017/11/10/a976/jo" id="rp2" showAs="Règlement grand-ducal du 10 novembre 2017 modifiant le règlement grand-ducal du 22 mars 2017 refixant pour l’année 2017 le montant annuel de référence 2017 tel que prévu à l’article 3 de la loi modifiée du 3 août 1998 sur la promotion de la presse écrite."/></references><notes scl:type="modification" source="#rp2"><note id="M1" marker="1" refersTo="pm1" title="A|2017-11-15|2017-11-10|RGD|976"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2017/11/10/a976/jo">Règlement grand-ducal du 10 novembre 2017 modifiant le règlement grand-ducal du 22 mars 2017 refixant pour l’année 2017 le montant annuel de référence 2017 tel que prévu à l’article 3 de la loi modifiée du 3 août 1998 sur la promotion de la presse écrite.</ref></p></content></note></notes></meta><preface><longTitle style="11"><p>Version consolidée applicable au 19/11/2017 : Règlement grand-ducal du 22 mars 2017 fixant pour l’année 2017 le montant annuel de référence 2017 tel que prévu à l’article 3 de la loi modifiée du 3 août 1998 sur la promotion de la presse écrite.</p></longTitle></preface><body><article id="art_1er"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336/art_1er</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336/art_1er/20171119</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux><scl:jolux scl:name="dateApplicability">2017-11-19</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num><mod class="mod-start" for="#pm1"/>Art. 1<sup>er</sup>.</num><alinea><content><p>Le montant annuel de référence prévu à l'article 3 de la <ref href="/eli/etat/leg/loi/1998/08/03/n13/jo" id="85486859-2632-4d8f-8676-b9ea7c4862d5">loi modifiée du 3 août 1998</ref> sur la promotion de la presse écrite est fixé comme suit pour l'an 2017 :</p><p scl:align="center">5 x 82.220 + 120 x 455 = 465.700 €.<mod class="mod-end" for="#pm1"/><noteRef href="#M1" marker="1"/></p></content></alinea></article><article id="art_2"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336/art_2</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336/art_2/20170401</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/03/22/a336</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 2.</scl:jolux><scl:jolux scl:name="dateApplicability">2017-04-01</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 2.</num><alinea><content><p>Notre Ministre des Communications et des Médias et notre Ministre des Finances sont chargés de l'exécution du présent règlement qui sera publié au Journal officiel du Grand-Duché de Luxembourg.</p></content></alinea></article></body></act></akomaNtoso>