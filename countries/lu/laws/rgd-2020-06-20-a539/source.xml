 id="e4" originatingExpression="true" source="#rp4" type="amendment"/></lifecycle><analysis source="#"><passiveModifications><textualMod id="pm1" incomplete="false" type="replacement"><source href="/eli/etat/leg/rgd/2020/12/15/a1026/jo"/><destination href="#art_3"/></textualMod><textualMod id="pm2" incomplete="false" type="replacement"><source href="/eli/etat/leg/rgd/2021/06/30/a488/jo"/><destination href="#art_3"/></textualMod><textualMod id="pm3" incomplete="false" type="replacement"><source href="/eli/etat/leg/rgd/2021/12/22/a921/jo"/><destination href="#art_3"/></textualMod></passiveModifications></analysis><references source="#"><original href="/eli/etat/leg/rgd/2020/06/20/a539/jo" id="ro1" showAs="Original"/><passiveRef href="/eli/etat/leg/rgd/2020/12/15/a1026/jo" id="rp2" showAs="Règlement grand-ducal du 15 décembre 2020 portant modification du règlement grand-ducal du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels."/><passiveRef href="/eli/etat/leg/rgd/2021/06/30/a488/jo" id="rp3" showAs="Règlement grand-ducal du 30 juin 2021 portant modification du règlement grand-ducal modifié du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels."/><passiveRef href="/eli/etat/leg/rgd/2021/12/22/a921/jo" id="rp4" showAs="Règlement grand-ducal du 22 décembre 2021 portant modification du règlement grand-ducal modifié du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels."/></references><notes scl:type="modification" source="#rp2"><note id="M1" marker="1" refersTo="pm1" title="A|2020-12-18|2020-12-15|RGD|1026"><content><p> <ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2020/12/15/a1026/jo">Règlement grand-ducal du 15 décembre 2020 portant modification du règlement grand-ducal du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels.</ref> </p></content></note></notes><notes scl:type="modification" source="#rp3"><note id="M2" marker="2" refersTo="pm2" title="A|2021-06-30|2021-06-30|RGD|488"><content><p> <ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2021/06/30/a488/jo">Règlement grand-ducal du 30 juin 2021 portant modification du règlement grand-ducal modifié du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels.</ref> </p></content></note></notes><notes scl:type="modification" source="#rp4"><note id="M3" marker="3" refersTo="pm3" title="A|2021-12-22|2021-12-22|RGD|921"><content><p> <ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2021/12/22/a921/jo">Règlement grand-ducal du 22 décembre 2021 portant modification du règlement grand-ducal modifié du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels.</ref> </p></content></note></notes></meta><preface><longTitle style="11"><p>Version consolidée applicable au 01/01/2022 : Règlement grand-ducal du 20 juin 2020 portant dérogation à l’article 2 du règlement grand-ducal modifié du 15 septembre 1975 portant fixation du taux d’indemnisation des chômeurs partiels. </p></longTitle></preface><body><article id="art_1er"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_1er</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_1er/20200625</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux><scl:jolux scl:name="dateApplicability">2020-06-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 1<sup>er</sup>.</num><alinea><content><p>Par dérogation à l’article 2 du <ref href="/eli/etat/leg/rgd/1975/09/15/n1/jo" id="89d70e9a-7e20-4458-a332-897add0b2f24" scl:verify="true">règlement grand-ducal modifié du 15 septembre 1975</ref> portant fixation du taux d’indemnisation des chômeurs partiels, l’indemnité de compensation ne peut pas être inférieure au taux du salaire social minimum pour salaires non qualifiés.</p></content></alinea><alinea><content><p scl:space-after="10">Le cas échéant celui-ci s’y substitue.</p></content></alinea></article><article id="art_2"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_2</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_2/20200625</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 2.</scl:jolux><scl:jolux scl:name="dateApplicability">2020-06-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 2.</num><alinea><content><p scl:space-after="10">Le <ref href="/eli/etat/leg/rgd/2020/03/27/a204/jo" id="ac227003-4b73-472b-828a-813e7e554cf9" scl:verify="true">règlement grand-ducal du 27 mars 2020</ref> portant modification temporaire de l’article 2 du <ref href="/eli/etat/leg/rgd/1975/09/15/n1/jo" id="0b15b348-1ffc-42f3-9b05-19a39b0dd2b8" scl:verify="true">règlement grand-ducal modifié du 15 septembre 1975</ref> portant fixation du taux d’indemnisation des chômeurs partiels est abrogé.</p></content></alinea></article><article id="art_3"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_3</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_3/20220101</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux><scl:jolux scl:name="dateApplicability">2022-01-01</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 3.</num><alinea><content><p>Le présent règlement entre en vigueur le jour de sa publication au Journal officiel du Grand-Duché de Luxembourg et s’applique <mod class="mod-start" for="#pm1"/>jusqu’au <mod class="mod-start" for="#pm2"/> <mod class="mod-start" for="#pm3"/>30 juin 2022<mod class="mod-end" for="#pm3"/> <noteRef href="#M3" marker="3"/> <mod class="mod-end" for="#pm1"> <mod class="mod-end" for="#pm2"/> <noteRef href="#M2" marker="2"/> </mod> <noteRef href="#M1" marker="1"/>.</p></content></alinea></article><article id="art_4"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_4</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539/art_4/20200625</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2020/06/20/a539</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 4.</scl:jolux><scl:jolux scl:name="dateApplicability">2020-06-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 4.</num><alinea><content><p>Notre ministre ayant le Travail dans ses attributions et Notre ministre ayant l’Économie dans ses attributions sont chargés, chacun en ce qui le concerne, de l’exécution du présent règlement qui sera publié au Journal officiel du Grand-Duché de Luxembourg.</p></content></alinea></article></body></act></akomaNtoso>