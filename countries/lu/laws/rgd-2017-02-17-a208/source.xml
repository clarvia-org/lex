<?xml version="1.0" encoding="UTF-8" standalone="no"?><akomaNtoso xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD13" xmlns:scl="http://www.scl.lu"><act contains="originalVersion" name=""><meta><identification source="#somebody"><FRBRWork><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208/consolide/20180603"/><FRBRuri value=""/><FRBRdate date="2017-02-17" name="document"/><FRBRauthor as="#author" href="http://data.legilux.public.lu/resource/authority/legal-institution/MAV"/><FRBRcountry value="http://publications.europa.eu/resource/authority/country/LUX"/></FRBRWork><FRBRExpression><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208/consolide/20180603/fr"/><FRBRuri value=""/><FRBRdate date="2017-02-17" name="document"/><FRBRauthor as="#author" href=""/><FRBRlanguage language="http://publications.europa.eu/resource/authority/language/FRA"/></FRBRExpression><FRBRManifestation><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208/consolide/20180603/fr/xml"/><FRBRuri value=""/><FRBRdate date="2017-02-17" name="document"/><FRBRauthor as="#author" href=""/></FRBRManifestation><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208/consolide/20180603</scl:jolux><scl:jolux scl:name="publicationDate">2021-09-29</scl:jolux><scl:jolux scl:name="typeDocument">http://data.legilux.public.lu/resource/authority/resource-type/RGD</scl:jolux><scl:jolux scl:name="dateDocument">2017-02-17</scl:jolux><scl:jolux scl:name="dateEntryInForce">2018-06-03</scl:jolux><scl:jolux scl:name="basicAct">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/02/17/a208</scl:jolux><scl:jolux scl:name="dateApplicability">2018-06-03</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legil