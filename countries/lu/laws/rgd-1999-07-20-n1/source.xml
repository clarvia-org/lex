</scl:JOLUXLegalResource>
</scl:JOLUXWork>
<num>Art. 7.</num>
<alinea>
<content>
<p>
<mod class="mod-start" for="#pm2"/>Les membres du comité ainsi que les experts ont droit à un jeton de présence qui est fixé à <mod class="mod-start" for="#pm3"/>
<mod class="mod-start" for="#pm4"/>10.70 €<mod class="mod-end" for="#pm3">
<mod class="mod-end" for="#pm4"/>
<noteRef href="#M4" marker="4"/>
</mod>
<noteRef href="#M3" marker="3"/> par séance.<mod class="mod-end" for="#pm2"/>
<noteRef href="#M2" marker="2"/>
</p>
</content>
</alinea>
</article>
