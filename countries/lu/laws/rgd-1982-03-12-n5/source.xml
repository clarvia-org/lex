			<chapter id="chapter_ii">
				<num>
					<b>II .</b>
				</num>
				<heading>
					<b>Nomination définitive</b>
				</heading>
				<article id="art_7">
					<scl:JOLUXWork>
						<scl:JOLUXComplexWork>
							<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1982/03/12/n5/art_7</scl:jolux>
						</scl:JOLUXComplexWork>
						<scl:JOLUXLegalResource>
							<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1982/03/12/n5/art_7/20040213</scl:jolux>
