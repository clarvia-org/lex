<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2016/12/23/n16/art_8</scl:jolux>
</scl:JOLUXComplexWork>
<scl:JOLUXLegalResource>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2016/12/23/n16/art_8/20161230</scl:jolux>
