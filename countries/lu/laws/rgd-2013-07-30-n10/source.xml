</content>
</alinea>
</article>
<article id="art_7">
<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2013/07/30/n10/art_7</scl:jolux>
