<li>Costa Rica</li>
<li>Israël</li>
<li>Kenya</li>
<li>Thaïlande.<mod class="mod-end" for="#pm9"/>
<noteRef href="#M9" marker="9"/>
</li>
</ol>
</content>
</alinea>
</paragraph>
<paragraph id="paragraph_8">
<num>(8)</num>
<alinea>
<content>
