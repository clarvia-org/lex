<ol scl:start="1" scl:symbol="1.">
<li>Les juridictions énumérées au paragraphe 7</li>
<li>Îles Féroé.<mod class="mod-end" for="#pm8"/>
<noteRef href="#M8" marker="8"/>
</li>
</ol>
</content>
</alinea>
</paragraph>
<paragraph id="paragraph_9">
<num>
<mod class="mod-start" for="#pm10"/>(9)</num>
<alinea>
<content>
