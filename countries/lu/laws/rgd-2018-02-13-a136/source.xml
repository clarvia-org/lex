</mod>
<noteRef href="#M3" marker="3"/>
</li>
</ol>
</content>
</alinea>
</paragraph>
<paragraph id="paragraph_5">
<num>
<mod class="mod-start" for="#pm6"/>(5)</num>
<alinea>
<content>
