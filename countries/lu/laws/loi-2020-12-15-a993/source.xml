<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2020/12/15/a993/art_4</scl:jolux>
</scl:JOLUXComplexWork>
<scl:JOLUXLegalResource>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2020/12/15/a993/art_4/20201215</scl:jolux>
<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/2020/12/15/a993</scl:jolux>
<scl:jolux scl:lg="fra" scl:name="title">Art. 4.</scl:jolux>
<scl:jolux scl:name="dateApplicability">2020-12-15</scl:jolux>
<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
</scl:JOLUXLegalResource>
</scl:JOLUXWork>
<num>Art. 4.</num>
<alinea>
<content>
<p>La présente loi entre en vigueur le jour de sa publication au Journal officiel du Grand-Duché de Luxembourg.</p>
</content>
</alinea>
</article>
</body>
