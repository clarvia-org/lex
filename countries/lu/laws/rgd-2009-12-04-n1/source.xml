<article id="art_1er">
<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2009/12/04/n1/art_1er</scl:jolux>
</scl:JOLUXComplexWork>
<scl:JOLUXLegalResource>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2009/12/04/n1/art_1er/20220606</scl:jolux>
