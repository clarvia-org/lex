						<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2017/08/29/a799</scl:jolux>
						<scl:jolux scl:lg="fra" scl:name="title">Art. 3. - Disposition finale</scl:jolux>
						<scl:jolux scl:name="dateApplicability">2017-09-15</scl:jolux>
						<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
					</scl:JOLUXLegalResource>
				</scl:JOLUXWork>
				<num>Art. 3.</num><heading scl:separator=" - "><b>Disposition finale</b>
				</heading>
				<alinea>
					<content>
						<p>Notre Ministre du Développement durable et des Infrastructures est chargé de l’exécution du présent règlement qui sera publié au Journal officiel du Grand-Duché de Luxembourg.</p>
					</content>
				</alinea>
			</article>
		</body>
