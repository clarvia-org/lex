<content>
<p scl:align="center">
<b>1. Direction</b>
</p>
</content>
</alinea>
<article id="art_1er">
<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2009/11/06/n4/art_1er</scl:jolux>
</scl:JOLUXComplexWork>
<scl:JOLUXLegalResource>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2009/11/06/n4/art_1er/20171224</scl:jolux>
<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2009/11/06/n4</scl:jolux>
<scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux>
<scl:jolux scl:name="dateApplicability">2017-12-24</scl:jolux>
<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
</scl:JOLUXLegalResource>
