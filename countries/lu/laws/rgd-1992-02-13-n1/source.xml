alMod><textualMod id="pm4" incomplete="false" type="replacement"><source href="/eli/etat/leg/rgd/2010/12/17/n8/jo"/><destination href="#art_2"/></textualMod></passiveModifications></analysis><references source="#"><original href="/eli/etat/leg/rgd/1992/02/13/n1/jo" id="ro1" showAs="Original"/><passiveRef href="/eli/etat/leg/rgd/2010/12/17/n8/jo" id="rp2" showAs="Règlement grand-ducal du 17 décembre 2010 portant modification du règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les programmes de radio locale."/></references><notes scl:type="modification" source="#rp2"><note id="M1" marker="1" refersTo="pm1" title="A|2010-12-24|2010-12-17|RGD|241"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2010/12/17/n8/jo">Règlement grand-ducal du 17 décembre 2010 portant modification du règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les programmes de radio locale.</ref></p></content></note></notes><notes scl:type="modification" source="#rp2"><note id="M2" marker="2" refersTo="pm2" title="A|2010-12-24|2010-12-17|RGD|241"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2010/12/17/n8/jo">Règlement grand-ducal du 17 décembre 2010 portant modification du règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les programmes de radio locale.</ref></p></content></note></notes><notes scl:type="modification" source="#rp2"><note id="M3" marker="3" refersTo="pm3" title="A|2010-12-24|2010-12-17|RGD|241"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2010/12/17/n8/jo">Règlement grand-ducal du 17 décembre 2010 portant modification du règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les programmes de radio locale.</ref></p></content></note></notes><notes scl:type="modification" source="#rp2"><note id="M4" marker="4" refersTo="pm4" title="A|2010-12-24|2010-12-17|RGD|241"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/rgd/2010/12/17/n8/jo">Règlement grand-ducal du 17 décembre 2010 portant modification du règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les programmes de radio locale.</ref></p></content></note></notes></meta><preface><longTitle><p>Version consolidée applicable au 28/12/2010 : Règlement grand-ducal du 13 février 1992 fixant les limites à imposer au volume des messages publicitaires pouvant être contenus dans les <mod class="mod-start" for="#pm1"/>services<mod class="mod-end" for="#pm1"/><noteRef href="#M1" marker="1"/> de radio locale.</p></longTitle></preface><body><article id="art_1er"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_1er</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_1er/20101228</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux><scl:jolux scl:name="dateApplicability">2010-12-28</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 1<sup>er</sup>.</num><alinea><content><p>Les <mod class="mod-start" for="#pm2"/>services<mod class="mod-end" for="#pm2"/><noteRef href="#M2" marker="2"/> de radio locale visés à l’article 17 de la <ref href="/eli/etat/leg/loi/1991/07/27/n1/jo" id="b0c2e8ca-f071-47ea-9002-22a005692c84">loi du 27 juillet 1991</ref> sur les médias électroniques sont autorisés à contenir des messages publicitaires dans les limites suivantes:</p><ol scl:symbol="a)"><li>les recettes publicitaires ne peuvent dépasser ni les frais réels occasionnés par le <mod class="mod-start" for="#pm3"/>service<mod class="mod-end" for="#pm3"/><noteRef href="#M3" marker="3"/>, y compris l’amortissement de l’émetteur et des autres équipements techniques, ni un montant de 12.394,68 euros par an;</li><li>le temps d’antenne consacré à la publicité ne peut pas être retenu à raison de plus de 10 % par un seul commerçant, une seule firme ou un seul groupe de firmes;</li><li>les messages publicitaires ne peuvent au total dépasser ni 6 minutes par heure d’antenne en moyenne journalière, ni 8 minutes pour une quelconque tranche horaire.</li></ol></content></alinea></article><article id="art_2"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_2</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_2/20101228</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 2.</scl:jolux><scl:jolux scl:name="dateApplicability">2010-12-28</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 2.</num><alinea><content><p>L’acquisition des messages publicitaires contenus dans les <mod class="mod-start" for="#pm4"/>services<mod class="mod-end" for="#pm4"/><noteRef href="#M4" marker="4"/> de radio locale doit être assurée par l’association bénéficiaire de la permission elle-même et ne peut être confiée à une régie, une agence publicitaire ou un autre intermédiaire professionnel.</p></content></alinea></article><article id="art_3"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_3</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_3/19920225</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux><scl:jolux scl:name="dateApplicability">1992-02-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 3.</num><alinea><content><p>Une association ayant renoncé, lors de la présentation de sa candidature, à la faculté de diffuser des messages publicitaires, ne peut diffuser de tels messages qu’après avoir obtenu une nouvelle permission prévoyant cette faculté.</p></content></alinea></article><article id="art_4"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_4</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_4/19920225</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 4.</scl:jolux><scl:jolux scl:name="dateApplicability">1992-02-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 4.</num><alinea><content><p>Le montant inscrit à l’article 1<sup>er</sup>, lettre a), peut être adapté par règlement grand-ducal.</p></content></alinea></article><article id="art_5"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_5</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1/art_5/19920225</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1992/02/13/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 5.</scl:jolux><scl:jolux scl:name="dateApplicability">1992-02-25</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 5.</num><alinea><content><p>Notre Premier Ministre, Ministre d’Etat, est chargé de l’exécution du présent règlement qui sera publié au Mémorial. </p></content></alinea></article></body></act></akomaNtoso>