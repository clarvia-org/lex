oi/1997/12/16/n1/jo</scl:jolux></scl:JOLUXExpression><scl:JOLUXManifestation><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/consolide/20180814/fr/xml</scl:jolux><scl:jolux scl:name="embodies">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/consolide/20180814/fr</scl:jolux><scl:jolux scl:name="memorialPage">682</scl:jolux><scl:jolux scl:name="publisher">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:lg="fra" scl:name="rights">Copyright : Ministère d’Etat – Service central de législation – du Grand-Duché de Luxembourg</scl:jolux><scl:jolux scl:name="rightsHolder">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:name="license">http://creativecommons.org/licenses/by/4.0/</scl:jolux><scl:jolux scl:name="userFormat">http://data.legilux.lu/resource/authority/user-format/xml-akomantoso</scl:jolux><scl:jolux scl:name="format">http://publications.europa.eu/resource/authority/file-type/XML</scl:jolux><scl:jolux scl:name="isExemplifiedBy">http://data.legilux.public.lu/file/eli-etat-leg-loi-2005-03-21-n1-consolide-20180814-fr-xml.xml</scl:jolux></scl:JOLUXManifestation><scl:JOLUXManifestation><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/consolide/20180814/fr/pdf</scl:jolux><scl:jolux scl:name="embodies">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/consolide/20180814/fr</scl:jolux><scl:jolux scl:name="memorialPage">682</scl:jolux><scl:jolux scl:name="publisher">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:lg="fra" scl:name="rights">Copyright : Ministère d’Etat – Service central de législation – du Grand-Duché de Luxembourg</scl:jolux><scl:jolux scl:name="rightsHolder">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:name="license">http://creativecommons.org/licenses/by/4.0/</scl:jolux><scl:jolux scl:name="userFormat">http://data.legilux.lu/resource/authority/user-format/pdf</scl:jolux><scl:jolux scl:name="format">http://publications.europa.eu/resource/authority/file-type/PDF</scl:jolux><scl:jolux scl:name="isExemplifiedBy">http://data.legilux.public.lu/file/eli-etat-leg-loi-2005-03-21-n1-consolide-20180814-fr-pdf.pdf</scl:jolux></scl:JOLUXManifestation></identification><lifecycle source="#"><eventRef date="2005-03-21" id="e1" originatingExpression="true" source="#ro1" type="generation"/><eventRef date="2018-08-14" id="e2" originatingExpression="true" source="#rp2" type="amendment"/></lifecycle><analysis source="#"><passiveModifications><textualMod id="pm1" incomplete="false" type="replacement"><source href="/eli/etat/leg/loi/2018/08/01/a673/jo"/><destination href="#art_2"/></textualMod><textualMod id="pm2" incomplete="false" type="insertion"><source href="/eli/etat/leg/loi/2018/08/01/a673/jo"/><destination href="#art_3"/></textualMod></passiveModifications></analysis><references source="#"><original href="/eli/etat/leg/loi/2005/03/21/n1/jo" id="ro1" showAs="Original"/><passiveRef href="/eli/etat/leg/loi/2018/08/01/a673/jo" id="rp2" showAs="Loi du 1er août 2018 portant modification de la loi du 21 mars 2005 autorisant l’acquisition d’un avion de transport militaire A400M."/></references><notes scl:type="modification" source="#rp2"><note id="M1" marker="1" refersTo="pm1" title="A|2018-08-10|2018-08-01|L|673"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/loi/2018/08/01/a673/jo">Loi du 1er août 2018 portant modification de la loi du 21 mars 2005 autorisant l’acquisition d’un avion de transport militaire A400M.</ref></p></content></note></notes><notes scl:type="modification" source="#rp2"><note id="M2" marker="2" refersTo="pm2" title="A|2018-08-10|2018-08-01|L|673"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/loi/2018/08/01/a673/jo">Loi du 1er août 2018 portant modification de la loi du 21 mars 2005 autorisant l’acquisition d’un avion de transport militaire A400M.</ref></p></content></note></notes></meta><preface><longTitle style="11"><p>Version consolidée applicable au 14/08/2018 : Loi du 21 mars 2005 autorisant l'acquisition d'un avion de transport militaire A400M.</p></longTitle></preface><body><article id="art_1er"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_1er</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_1er/20050408</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux><scl:jolux scl:name="dateApplicability">2005-04-08</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 1<sup>er</sup>.</num><alinea><content><p>Le Gouvernement est autorisé à acquérir, par l'intermédiaire de la Belgique, un avion de transport militaire A400M répondant aux conditions de la fiche européenne de caractéristique militaire.</p></content></alinea></article><article id="art_2"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_2</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_2/20180814</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 2.</scl:jolux><scl:jolux scl:name="dateApplicability">2018-08-14</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num><u><mod class="mod-start" for="#pm1"/>Art. 2.</u></num><alinea><content><p>Les dépenses occasionnées par l’acquisition de l’avion de transport militaire A400M ne peuvent dépasser le montant de cent vingt millions d’euros à prix constants aux conditions économiques de juin 2001 sans préjudice d’une adaptation des paiements annuels en fonction de l’évolution des conditions économiques telle que déterminée par l’évolution du déflateur PIB applicable à la zone euro. Ce montant ne comprend pas la taxe sur la valeur ajoutée, les taxes, les droits de douane et les charges similaires liés à l’acquisition de l’avion de transport militaire A400M.</p></content></alinea><alinea><content><p>Les dépenses occasionnées par l’exploitation, le fonctionnement et le soutien en service de l’avion de transport militaire A400M sur une durée estimée de trente-cinq ans, ne peuvent dépasser le montant de 420 000 000 euros à prix constants aux conditions économiques d’octobre 2017 sans préjudice d’une adaptation des paiements annuels en fonction de l’évolution des conditions économiques telle que déterminée par l’évolution du déflateur PIB applicable à la zone euro. Ce montant ne comprend pas la taxe sur la valeur ajoutée, les taxes et les droits de douane.<mod class="mod-end" for="#pm1"/><noteRef href="#M1" marker="1"/></p></content></alinea></article><article id="art_3"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_3</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1/art_3/20180814</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/2005/03/21/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux><scl:jolux scl:name="dateApplicability">2018-08-14</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 3.</num><alinea><content><p>Les dépenses occasionnées par l'acquisition de l'avion de transport militaire A400M sont liquidées à charge du fonds d'équipement militaire créé par l'article 2 de la <ref href="/eli/etat/leg/loi/1997/12/16/n1/jo" id="e1c0ba34-a9ae-4d2e-801e-e3427670dcf1" scl:verify="true">loi du 16 décembre 1997</ref> concernant la programmation financière militaire.</p></content></alinea><alinea><content><p><mod class="mod-start" for="#pm2"/>Les dépenses occasionnées par l’exploitation, le fonctionnement et le soutien en service de l’avion de transport militaire A400M sont à charge des crédits de la Direction de la Défense.<mod class="mod-end" for="#pm2"/><noteRef href="#M2" marker="2"/></p></content></alinea></article></body></act></akomaNtoso>