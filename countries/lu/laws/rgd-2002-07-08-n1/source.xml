                        <scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux>
                        <scl:jolux scl:name="dateApplicability">2002-08-01</scl:jolux>
                        <scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
                    </scl:JOLUXLegalResource>
                </scl:JOLUXWork>
                <num>Art. 3.</num>
                <alinea>
                    <content>
                        <p>Notre Ministre des Finances est chargé de l’exécution du présent règlement qui sera publié au Mémorial.</p>
                    </content>
                </alinea>
            </article>
