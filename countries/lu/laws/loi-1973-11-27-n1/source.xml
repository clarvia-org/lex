<?xml version="1.0" encoding="UTF-8"?><akomaNtoso xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD13" xmlns:scl="http://www.scl.lu"><act contains="originalVersion" name=""><meta><identification source="#casemates"><FRBRWork><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo"/><FRBRuri value=""/><FRBRdate date="1973-11-27" name="document"/><FRBRauthor as="#author" href="http://data.legilux.public.lu/resource/authority/legal-institution/MECM"/><FRBRcountry value="http://publications.europa.eu/resource/authority/country/LUX"/></FRBRWork><FRBRExpression><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr"/><FRBRuri value=""/><FRBRdate date="1973-11-27" name="document"/><FRBRauthor as="#author" href=""/><FRBRlanguage language="http://publications.europa.eu/resource/authority/language/FRA"/></FRBRExpression><FRBRManifestation><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr/xml"/><FRBRuri value=""/><FRBRdate date="1973-11-27" name="document"/><FRBRauthor as="#author" href=""/></FRBRManifestation><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo</scl:jolux><scl:jolux scl:name="dateApplicability">2004-07-02</scl:jolux><scl:jolux scl:name="dateDocument">1973-11-27</scl:jolux><scl:jolux scl:name="responsibilityOf">http://data.legilux.public.lu/resource/authority/legal-institution/MECM</scl:jolux><scl:jolux scl:name="subjectLevel2">http://data.legilux.public.lu/resource/authority/legal-subject/559</scl:jolux><scl:jolux scl:name="subjectLevel2">http://data.legilux.public.lu/resource/authority/legal-subject/623</scl:jolux><scl:jolux scl:name="subjectLevel1">http://data.legilux.public.lu/resource/authority/legal-subject/836</scl:jolux><scl:jolux scl:name="isRealizedBy">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr</scl:jolux><scl:jolux scl:name="dateEntryInForce">1973-12-23</scl:jolux><scl:jolux scl:name="isPartOf">http://data.legilux.public.lu/eli/etat/leg/memorial/1973/a78</scl:jolux><scl:jolux scl:name="historicalLegalId">1973A16801</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1</scl:jolux><scl:jolux scl:name="typeDocument">http://data.legilux.public.lu/resource/authority/resource-type/LOI</scl:jolux><scl:jolux scl:name="publicationDate">1973-12-19</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Act</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#LegalResource</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#NationalLegalResource</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Work</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><scl:JOLUXExpression><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr</scl:jolux><scl:jolux scl:name="isEmbodiedBy">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr/html</scl:jolux><scl:jolux scl:name="isEmbodiedBy">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr/pdf</scl:jolux><scl:jolux scl:name="isEmbodiedBy">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr/xml</scl:jolux><scl:jolux scl:name="isEmbodiedBy">http://data.legilux.public.lu/eli/etat/leg/loi/1973/11/27/n1/jo/fr/docx</scl:jolux><scl:jolux scl:name="cites">/eli/etat/leg/argd/1872/06/17/n1/jo</scl:jolux><scl:jolux scl:name="cites">/eli/etat/leg/loi/1859/12/17/n5/jo</scl:jolux><scl:jolux scl:name="cites">/eli/etat/leg/loi/1879/06/18/n2/jo</scl:jolux><scl:jolux scl:name="cites">/eli/etat/leg/loi/1915/08/10/n1/jo</scl:jolux><scl:jolux scl:name="language">http://publications.europa.eu/r