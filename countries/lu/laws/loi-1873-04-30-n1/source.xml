<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1873/04/30/n1</scl:jolux>
<scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux>
<scl:jolux scl:name="dateApplicability">2016-09-01</scl:jolux>
<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
