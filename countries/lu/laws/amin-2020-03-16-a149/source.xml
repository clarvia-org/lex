						<scl:JOLUXLegalResource>
							<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/amin/2020/03/16/a149/art_7/20200316</scl:jolux>
							<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/amin/2020/03/16/a149</scl:jolux>
							<scl:jolux scl:lg="fra" scl:name="title">Art. 7.</scl:jolux>
							<scl:jolux scl:name="dateApplicability">2020-03-16</scl:jolux>
