					<scl:JOLUXWork>
						<scl:JOLUXComplexWork>
							<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/amin/2020/03/16/a149/art_6</scl:jolux>
						</scl:JOLUXComplexWork>
						<scl:JOLUXLegalResource>
							<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/amin/2020/03/16/a149/art_6/20200316</scl:jolux>
							<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/amin/2020/03/16/a149</scl:jolux>
							<scl:jolux scl:lg="fra" scl:name="title">Art. 6.</scl:jolux>
							<scl:jolux scl:name="dateApplicability">2020-03-16</scl:jolux>
							<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
						</scl:JOLUXLegalResource>
					</scl:JOLUXWork>
					<num>Art. 6.</num>
					<alinea>
						<content>
							<p>Le présent arrêté entre en vigueur le 16 mars 2020.</p>
						</content>
					</alinea>
				</article>
