<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2015/12/18/n6/art_4</scl:jolux>
</scl:JOLUXComplexWork>
