<?xml version="1.0" encoding="UTF-8" standalone="no"?><akomaNtoso xmlns="http://docs.oasis-open.org/legaldocml/ns/akn/3.0/CSD13" xmlns:scl="http://www.scl.lu"><act contains="originalVersion" name="" scl:page-proof="many"><meta><identification source="#somebody"><FRBRWork><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607/consolide/20190101"/><FRBRuri value=""/><FRBRdate date="2018-07-13" name="document"/><FRBRauthor as="#author" href="http://data.legilux.public.lu/resource/authority/legal-institution/MI"/><FRBRcountry value="http://publications.europa.eu/resource/authority/country/LUX"/></FRBRWork><FRBRExpression><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607/consolide/20190101/fr"/><FRBRuri value=""/><FRBRdate date="2018-07-13" name="document"/><FRBRauthor as="#author" href=""/><FRBRlanguage language="http://publications.europa.eu/resource/authority/language/FRA"/></FRBRExpression><FRBRManifestation><FRBRthis value="http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607/consolide/20190101/fr/xml"/><FRBRuri value=""/><FRBRdate date="2018-07-13" name="document"/><FRBRauthor as="#author" href=""/></FRBRManifestation><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607/consolide/20190101</scl:jolux><scl:jolux scl:name="publicationDate">2021-05-31</scl:jolux><scl:jolux scl:name="typeDocument">http://data.legilux.public.lu/resource/authority/resource-type/RGD</scl:jolux><scl:jolux scl:name="dateDocument">2018-07-13</scl:jolux><scl:jolux scl:name="dateEntryInForce">2019-01-01</scl:jolux><scl:jolux scl:name="dateApplicability">2019-01-01</scl:jolux><scl:jolux scl:name="basicAct">http://data.legilux.public.lu/eli/etat/leg/rgd/2018/07/13/a607</scl:jolux><scl:jolux scl:name="isMember