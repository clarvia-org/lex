<article id="art_1er">
<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2022/03/09/a101/art_1er</scl:jolux>
