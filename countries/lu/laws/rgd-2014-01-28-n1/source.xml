<article id="art_1er">
<scl:JOLUXWork>
<scl:JOLUXComplexWork>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2014/01/28/n1/art_1er</scl:jolux>
</scl:JOLUXComplexWork>
<scl:JOLUXLegalResource>
<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/2014/01/28/n1/art_1er/20140525</scl:jolux>
