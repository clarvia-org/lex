olux><scl:jolux scl:name="publicationDate">1957-07-23</scl:jolux><scl:jolux scl:name="historicalLegalId">1957A10091</scl:jolux><scl:jolux scl:name="dateEntryInForce">1957-07-26</scl:jolux><scl:jolux scl:name="isPartOf">http://data.legilux.public.lu/eli/etat/leg/memorial/1957/44</scl:jolux><scl:jolux scl:name="subjectLevel1">http://data.legilux.public.lu/resource/authority/legal-subject/955</scl:jolux><scl:jolux scl:name="subjectLevel2">http://data.legilux.public.lu/resource/authority/legal-subject/496</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#BaseAct</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Act</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Work</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#LegalResource</scl:rdf><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#NationalLegalResource</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><scl:JOLUXExpression><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/jo/fr</scl:jolux><scl:jolux scl:name="realizes">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/jo</scl:jolux><scl:jolux scl:name="language">http://publications.europa.eu/resource/authority/language/FRA</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Version consolidée applicable au 01/02/2023 : Loi du 11 juillet 1957 portant réglementation du camping.</scl:jolux><scl:jolux scl:name="draft">http://data.legilux.public.lu/eli/etat/proj/PL/00002221</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Loi du 11 juillet 1957 portant réglementation du camping.</scl:jolux></scl:JOLUXExpression><scl:JOLUXManifestation><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/jo/fr/xml</scl:jolux><scl:jolux scl:name="embodies">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/jo/fr</scl:jolux><scl:jolux scl:name="publishedIn">http://data.legilux.public.lu/eli/etat/leg/memorial/1957/44/fr/pdf</scl:jolux><scl:jolux scl:name="memorialPage">1009</scl:jolux><scl:jolux scl:name="memorialSequence">1</scl:jolux><scl:jolux scl:name="publisher">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:lg="fra" scl:name="rights">Copyright : Ministère d’Etat – Service central de législation – du Grand-Duché de Luxembourg</scl:jolux><scl:jolux scl:name="rightsHolder">http://data.legilux.public.lu/authority/legal-institution/ME</scl:jolux><scl:jolux scl:name="license">http://creativecommons.org/licenses/by/4.0/</scl:jolux><scl:jolux scl:name="userFormat">http://data.legilux.lu/resource/authority/user-format/xml-akomantoso</scl:jolux><scl:jolux scl:name="format">http://publications.europa.eu/resource/authority/file-type/XML</scl:jolux><scl:jolux scl:name="isExemplifiedBy">http://data.legilux.public.lu/file/eli-etat-leg-loi-1957-07-11-n1-jo-fr-xml.xml</scl:jolux></scl:JOLUXManifestation></identification><lifecycle source="#"><eventRef date="1957-07-11" id="e1" originatingExpression="true" source="#ro1" type="generation"/><eventRef date="2023-02-01" id="e2" originatingExpression="true" source="#rp2" type="amendment"/></lifecycle><analysis source="#"><passiveModifications><textualMod id="pm1" incomplete="false" type="substitution"><source href="/eli/etat/leg/loi/2023/01/06/a30/jo"/><destination href="#art_8"/></textualMod></passiveModifications></analysis><references source="#"><original href="/eli/etat/leg/loi/1957/07/11/n1/jo" id="ro1" showAs="Original"/><passiveRef href="/eli/etat/leg/loi/2023/01/06/a30/jo" id="rp2" showAs="Loi du 6 janvier 2023 portant modification : 1° de la loi communale modifiée du 13 décembre 1988 ; 2° de l’article 2045 du Code civil ; 3° de la loi du 11 juillet 1957 portant réglementation du camping ; 4° de la loi modifiée du 24 décembre 1985 fixant le statut général des fonctionnaires communaux ; 5° de la loi modifiée du 7 novembre 1996 portant organisation des juridictions de l’ordre administratif ; 6° de la loi modifiée du 23 février 2001 concernant les syndicats de communes ; 7° de la loi électorale modifiée du 18 février 2003 ; 8° de la loi modifiée du 8 avril 2018 sur les marchés publics ; 9° de la loi modifiée du 24 juin 2020 portant introduction de mesures temporaires relatives à la loi communale modifiée du 13 décembre 1988 et à la loi modifiée du 27 mars 2018 portant organisation de la sécurité civile dans le cadre de la lutte contre le Covid-19. "/></references><notes scl:type="modification" source="#rp2"><note id="M1" marker="1" refersTo="pm1" title="A|2023-01-19|2023-01-06|L|30"><content><p><ref href="http://data.legilux.public.lu/eli/etat/leg/loi/2023/01/06/a30/jo">Loi du 6 janvier 2023 portant modification : 1° de la loi communale modifiée du 13 décembre 1988 ; 2° de l’article 2045 du Code civil ; 3° de la loi du 11 juillet 1957 portant réglementation du camping ; 4° de la loi modifiée du 24 décembre 1985 fixant le statut général des fonctionnaires communaux ; 5° de la loi modifiée du 7 novembre 1996 portant organisation des juridictions de l’ordre administratif ; 6° de la loi modifiée du 23 février 2001 concernant les syndicats de communes ; 7° de la loi électorale modifiée du 18 février 2003 ; 8° de la loi modifiée du 8 avril 2018 sur les marchés publics ; 9° de la loi modifiée du 24 juin 2020 portant introduction de mesures temporaires relatives à la loi communale modifiée du 13 décembre 1988 et à la loi modifiée du 27 mars 2018 portant organisation de la sécurité civile dans le cadre de la lutte contre le Covid-19.</ref> </p></content></note></notes></meta><preface><longTitle style="11"><p>Version consolidée applicable au 01/02/2023 : Loi du 11 juillet 1957 portant réglementation du camping.</p></longTitle></preface><body><article id="art_1er"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_1er</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_1er/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 1er.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 1<sup>er</sup>.</num><alinea><content><p>Est considéré comme terrain de camping public toute propriété mise publiquement à la disposition des campeurs ou occupée en fait et d'une manière habituelle par des groupes de campeurs.</p></content></alinea></article><article id="art_2"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_2</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_2/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 2.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 2.</num><alinea><content><p>L'ouverture ou le maintien d'un terrain de camping public est soumis à une autorisation écrite du Membre du Gouvernement ayant dans ses attributions le tourisme, le médecin-inspecteur compétent entendu en son avis.</p></content></alinea><alinea><content><p>L'autorisation qui aura une validité de cinq ans pourra être renouvelée sur demande écrite du propriétaire ou de la personne qui a la jouissance du terrain. La demande en renouvellement sera présentée trois mois avant l'expiration de l'autorisation en cours.</p></content></alinea><alinea><content><p>L'autorisation pourra être retirée ou suspendue si le terrain ne remplit plus les conditions prévues par la présente loi et les réglements d'administration publique à intervenir. Le retrait ou la suspension de l'autorisation ne sera prononcée par le Membre du Gouvernement compétent qu'après une mise en demeure écrite adressée au propriétaire ou à la personne qui a la jouissance du terrain.</p></content></alinea></article><article id="art_3"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_3</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_3/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 3.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 3.</num><alinea><content><p>Sans préjudice des prescriptions de la présente loi, un règlement d'administration publique déterminera les conditions auxquelles doivent satisfaire les terrains de camping public, énumérera les endroits où il sera interdit d'aménager pareils terrains et fera le classement de ces terrains.</p></content></alinea></article><article id="art_4"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_4</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_4/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 4.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 4.</num><alinea><content><p>Tout terrain affecté au camping conformément à la présente loi, sera doté par le pro- priétaire ou par l'exploitant d'un règlement d'ordre intérieur. Ce règlement qui devra être préalablement soumis à l'approbation du Membre du Gouvernement ayant le tourisme dans ses attributions, sera affiché en un endroit apparent du camp.</p></content></alinea><alinea><content><p>Il doit assurer le maintien de la discipline et du bon état du matériel du camp et du terrain, le respect de l'hygiène, de la décence, de l'ordre public, du couvre-feu, du bon fonctionnement du camp en général ainsi que des tarifs appliqués.</p></content></alinea><alinea><content><p>Il est interdit à toute personne autre que le propriétaire d'un terrain de camping public d'y installer des tentes ou roulottes en vue de les souslouer ou pour y recevoir des voyageurs de passage.</p></content></alinea></article><article id="art_5"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_5</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_5/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 5.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 5.</num><alinea><content><p>Les redevances maxima qui pourront être perçues pour l'utilisation des terrains de camping visés par la présente loi, seront fixées par règlement d'administration publique.</p></content></alinea></article><article id="art_6"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_6</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_6/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 6.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 6.</num><alinea><content><p>Pour camper sur tous terrains privés, autres que ceux qui sont visés par la présente loi, il faut la permission du propriétaire, de la personne qui en a la jouissance ou de son représentant.</p></content></alinea><alinea><content><p>La permission peut être tacite.</p></content></alinea></article><article id="art_7"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_7</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_7/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 7.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 7.</num><alinea><content><p>Nul ne peut pénétrer dans une tente, dans une voiture ou dans une remorque de camping installées dans un camp, sans le consentement du propriétaire ou de son représentant, hors les cas prévus par la loi et dans les formes qu'elle prescrit.</p></content></alinea></article><article id="art_8"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_8</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_8/20230201</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 8.</scl:jolux><scl:jolux scl:name="dateApplicability">2023-02-01</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 8.</num><alinea><content><p>Les règlements des administrations communales tendant à interdire ou a restreindre l'établiseement de terrains de camping publics ou le camping sur terrains privés, doivent être approuvés par <mod class="mod-start" for="#pm1"/><del>le Ministre de l'Intérieur et<mod class="mod-end" for="#pm1"/></del><noteRef href="#M1" marker="1"/> le Ministre qui a dans ses attributions le tourisme.</p></content></alinea></article><article id="art_9"><scl:JOLUXWork><scl:JOLUXComplexWork><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_9</scl:jolux></scl:JOLUXComplexWork><scl:JOLUXLegalResource><scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1/art_9/19570726</scl:jolux><scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/loi/1957/07/11/n1</scl:jolux><scl:jolux scl:lg="fra" scl:name="title">Art. 9.</scl:jolux><scl:jolux scl:name="dateApplicability">1957-07-26</scl:jolux><scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf></scl:JOLUXLegalResource></scl:JOLUXWork><num>Art. 9.</num><alinea><content><p>Sans préjudice des peines prévues par d'autres dispositions, les infractions à la présente loi et aux règlements d'administration publique à intervenir seront punies d'une amende de 1 à 13 euros et d'un emprisonnement d'un à sept jours ou d'une de ces peines seulement.</p></content></alinea></article></body></act></akomaNtoso>