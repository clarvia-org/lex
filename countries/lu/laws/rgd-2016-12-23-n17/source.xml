<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/2016/12/23/n17</scl:jolux>
<scl:jolux scl:lg="fra" scl:name="title">Art. 6.</scl:jolux>
<scl:jolux scl:name="dateApplicability">2016-12-30</scl:jolux>
<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
