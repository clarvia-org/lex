			<article id="art_4">
				<scl:JOLUXWork>
					<scl:JOLUXComplexWork>
						<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1997/07/27/n5/art_4</scl:jolux>
					</scl:JOLUXComplexWork>
					<scl:JOLUXLegalResource>
						<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1997/07/27/n5/art_4/20160915</scl:jolux>
