						<scl:jolux scl:lg="fra" scl:name="title">Art. 4.</scl:jolux>
						<scl:jolux scl:name="dateApplicability">2016-09-15</scl:jolux>
						<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
					</scl:JOLUXLegalResource>
				</scl:JOLUXWork>
				<num>Art. 4.</num>
				<heading>
					<b>Disposition transitoire</b>
				</heading>
				<alinea>
					<content>
						<p>Les chargés de cours à durée déterminée, en service au premier janvier 1997 et repris en qualité de chargé d’éducation à durée indéterminée, sont dispensés des épreuves du contrôle linguistique prévu à l’article 2, sub 5 ci-dessus.</p>
					</content>
				</alinea>
			</article>
			<article id="art_5">
				<scl:JOLUXWork>
					<scl:JOLUXComplexWork>
						<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1997/07/27/n5/art_5</scl:jolux>
					</scl:JOLUXComplexWork>
					<scl:JOLUXLegalResource>
						<scl:jolux scl:name="uriThis">http://data.legilux.public.lu/eli/etat/leg/rgd/1997/07/27/n5/art_5/20160915</scl:jolux>
						<scl:jolux scl:name="isMemberOf">http://data.legilux.public.lu/eli/etat/leg/rgd/1997/07/27/n5</scl:jolux>
						<scl:jolux scl:lg="fra" scl:name="title">Art. 5.</scl:jolux>
						<scl:jolux scl:name="dateApplicability">2016-09-15</scl:jolux>
						<scl:rdf scl:name="type">http://data.legilux.public.lu/resource/ontology/jolux#Article</scl:rdf>
					</scl:JOLUXLegalResource>
